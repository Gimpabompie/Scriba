<Window x:Class="Notulen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scriba — offline spraak naar tekst"
        Height="760" Width="880" MinHeight="620" MinWidth="740"
        Background="{StaticResource Bg}"
        FontFamily="{StaticResource UiFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Koptekst -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}">
            <StackPanel Margin="20,16">
                <TextBlock Text="📝  Scriba" Foreground="White"
                           FontSize="22" FontWeight="Bold" />
                <TextBlock x:Name="SubtitleText"
                           Text="Offline spraak naar tekst · Nederlands &amp; Engels"
                           Foreground="#FFE0E7FF" FontSize="12" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <!-- Hoofdgebied -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12">
            <StackPanel>

                <!-- Kaart: instellingen -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Taal"
                                   Style="{StaticResource Head}" Margin="0,0,12,2" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Model"
                                   Style="{StaticResource Head}" Margin="0,0,12,2" />

                        <ComboBox x:Name="LangBox" Grid.Row="1" Grid.Column="0"
                                  Width="220" Margin="0,0,12,0" />
                        <ComboBox x:Name="ModelBox" Grid.Row="1" Grid.Column="1"
                                  Width="120" Margin="0,0,16,0" />
                        <StackPanel Grid.Row="1" Grid.Column="2" VerticalAlignment="Center">
                            <CheckBox x:Name="LiveBox" Content="Live transcriberen (tijdens spreken)" />
                            <CheckBox x:Name="TimestampsBox" Content="Tijdstempels" Margin="0,4,0,0" />
                            <CheckBox x:Name="VadBox" Content="Stilte/ruis filteren (minder hallucinatie)" Margin="0,4,0,0" />
                            <CheckBox x:Name="DiarizeBox" Content="Sprekers herkennen" Margin="0,4,0,0" />
                        </StackPanel>

                        <Separator Grid.Row="2" Grid.ColumnSpan="3" Margin="0,12"
                                   Background="{StaticResource Border}" />

                        <TextBlock Grid.Row="3" Grid.ColumnSpan="3" Text="Audiobron"
                                   Style="{StaticResource Head}" Margin="0,0,0,2" />
                        <Grid Grid.Row="4" Grid.ColumnSpan="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="DeviceBox" Grid.Column="0" />
                            <Button x:Name="RefreshBtn" Grid.Column="1" Content="↻ Verversen"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="8,0,0,0" Click="Refresh_Click" />
                        </Grid>
                        <DockPanel Grid.Row="5" Grid.ColumnSpan="3" Margin="0,8,0,0">
                            <Button x:Name="OpenRecordingsBtn" DockPanel.Dock="Right"
                                    Content="📂  Opnamemap openen" Padding="10,6"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="OpenRecordings_Click" />
                            <CheckBox x:Name="SaveAudioBox" VerticalAlignment="Center"
                                      Content="Opname bewaren als .wav" />
                        </DockPanel>
                    </Grid>
                </Border>

                <!-- Kaart: woordenlijst -->
                <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Woordenlijst" Style="{StaticResource Head}" />
                        <TextBlock Text="Namen &amp; vaktermen (komma's of nieuwe regels) — voor correcte spelling."
                                   Style="{StaticResource MutedText}" Margin="0,0,0,6" />
                        <TextBox x:Name="VocabBox" Height="48" TextWrapping="Wrap"
                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                 Background="{StaticResource Soft}" BorderBrush="{StaticResource Border}"
                                 Padding="6" />
                    </StackPanel>
                </Border>

                <!-- Actierij -->
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="RecordBtn" Grid.Column="0" Content="●  Opname starten"
                            Style="{StaticResource AccentButton}" Click="Record_Click" />
                    <Button x:Name="FileBtn" Grid.Column="1" Content="📁  Audiobestand…"
                            Style="{StaticResource SecondaryButton}" Margin="10,0,0,0"
                            Click="LoadFile_Click" />
                    <StackPanel Grid.Column="3" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Niveau" Style="{StaticResource MutedText}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ProgressBar x:Name="LevelBar" Width="200" Height="14"
                                     Minimum="0" Maximum="100"
                                     Foreground="{StaticResource Good}"
                                     Background="#FFE6E9F0" BorderThickness="0" />
                        <TextBlock x:Name="LevelHint" Style="{StaticResource MutedText}"
                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>

                <!-- Kaart: transcript -->
                <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0"
                        MinHeight="240">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                            <TextBlock Text="Transcript" Style="{StaticResource Head}"
                                       VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="ClearBtn" Content="Wissen"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0" Click="Clear_Click" />
                                <Button x:Name="RenameSpeakersBtn" Content="🧑  Sprekers hernoemen"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0" IsEnabled="False" Click="RenameSpeakers_Click" />
                                <Button x:Name="CorrectBtn" Content="🪄  Corrigeer"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0" IsEnabled="False" Click="Correct_Click" />
                                <Button x:Name="SummarizeBtn" Content="✨  Vat samen"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0" IsEnabled="False" Click="Summarize_Click" />
                                <Button x:Name="SaveBtn" Content="💾  Notulen opslaan"
                                        Style="{StaticResource SecondaryButton}"
                                        IsEnabled="False" Click="Save_Click" />
                            </StackPanel>
                        </Grid>
                        <TextBox x:Name="TranscriptBox" TextWrapping="Wrap"
                                 AcceptsReturn="True" IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto" FontSize="14"
                                 BorderBrush="{StaticResource Border}" Background="White"
                                 Padding="10" MinHeight="180"
                                 Foreground="{StaticResource Muted}"
                                 Text="Het transcript verschijnt hier zodra je opneemt of een audiobestand laadt." />
                    </DockPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Statusbalk -->
        <Border Grid.Row="2" Background="{StaticResource Card}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Margin="12,5">
                <TextBlock x:Name="StatusDot" Text="●" Foreground="{StaticResource Good}"
                           VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBlock x:Name="StatusText" Text="Klaar."
                           Style="{StaticResource MutedText}" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
