<Window x:Class="Notulen.RenameSpeakersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sprekers hernoemen" Height="420" Width="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg}" FontFamily="{StaticResource UiFont}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Geef elke spreker een naam:"
                   Style="{StaticResource Head}" Margin="0,0,0,8" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="RowsPanel" />
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Annuleren" Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0" Click="Cancel_Click" />
            <Button Content="Toepassen" Style="{StaticResource AccentButton}"
                    Click="Ok_Click" />
        </StackPanel>
    </Grid>
</Window>
