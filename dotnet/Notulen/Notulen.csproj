<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>Scriba</AssemblyName>
    <RootNamespace>Notulen</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Version>1.0.0</Version>
    <!-- LLamaSharp.Backend.Cpu levert meerdere CPU-varianten (avx/avx2/…) van
         dezelfde native DLL's; sta dat toe bij publiceren (NETSDK1152). -->
    <ErrorOnDuplicatePublishOutputFiles>false</ErrorOnDuplicatePublishOutputFiles>
  </PropertyGroup>

  <ItemGroup>
    <!-- Audio-opname (microfoon + WASAPI-loopback voor systeemaudio) -->
    <PackageReference Include="NAudio" Version="2.2.1" />
    <!-- Offline transcriptie via whisper.cpp -->
    <PackageReference Include="Whisper.net" Version="1.9.1" />
    <PackageReference Include="Whisper.net.Runtime" Version="1.9.1" />
    <!-- Offline samenvatting via een lokaal taalmodel (llama.cpp) -->
    <PackageReference Include="LLamaSharp" Version="0.24.0" />
    <PackageReference Include="LLamaSharp.Backend.Cpu" Version="0.24.0" />
    <!-- Offline sprekerherkenning (diarization) -->
    <PackageReference Include="org.k2fsa.sherpa.onnx" Version="1.13.3" />
    <!-- Uitpakken van het segmentatiemodel (.tar.bz2) -->
    <PackageReference Include="SharpCompress" Version="1.0.0" />
  </ItemGroup>

</Project>
