<Window x:Class="Notulen.SummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Samenvatting" Height="560" Width="640" MinHeight="400" MinWidth="480"
        Background="{StaticResource Bg}" FontFamily="{StaticResource UiFont}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📋  Samenvatting" Style="{StaticResource Head}"
                   FontSize="16" Margin="0,0,0,4" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <ProgressBar x:Name="ProgBar" Width="160" Height="12" Minimum="0" Maximum="100"
                         Foreground="{StaticResource Accent}" Background="#FFE6E9F0"
                         BorderThickness="0" Visibility="Collapsed"
                         VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBlock x:Name="StatusText" Text="Bezig…" Style="{StaticResource MutedText}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <TextBox x:Name="SummaryBox" TextWrapping="Wrap" AcceptsReturn="True"
                     IsReadOnly="True" VerticalScrollBarVisibility="Auto" FontSize="14"
                     BorderThickness="0" Background="White" Padding="12" />
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="CopyBtn" Content="Kopiëren" Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0" Click="Copy_Click" IsEnabled="False" />
            <Button x:Name="SaveBtn" Content="💾  Opslaan" Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0" Click="Save_Click" IsEnabled="False" />
            <Button x:Name="CloseBtn" Content="Sluiten" Style="{StaticResource SecondaryButton}"
                    Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
